generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Attachment {
  id            String   @id
  sessionId     String
  name          String
  mimeType      String
  size          Int
  kind          String
  uploadedAt    DateTime
  extractedText String
  storagePath   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sessionId, uploadedAt(sort: Desc)])
}
